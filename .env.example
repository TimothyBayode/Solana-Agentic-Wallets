# Solana Agent Wallet — Environment Configuration
# Copy to .env and fill in values

# Password used to encrypt/decrypt agent keystores
# IMPORTANT: Use a strong password in production
WALLET_PASSWORD=dev-secret-change-in-prod

# Dashboard port
PORT=3000

# Solana RPC endpoint (defaults to devnet if not set)
# For production, use a paid provider: Helius, Triton, QuickNode
# RPC_URL=https://api.devnet.solana.com
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Network: devnet | mainnet-beta | testnet
NETWORK=devnet
